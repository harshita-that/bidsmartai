# ── Frontend (Next.js) Environment Variables ──────────────────────
# Copy to .env.local for local development

# Public API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# App base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (optional - if using Supabase for storage or realtime)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe public key (for Stripe.js on the frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth client ID (for Google Sign-In button)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Feature flags
NEXT_PUBLIC_ENABLE_PHOTO_LOOKUP=false
NEXT_PUBLIC_MAINTENANCE_MODE=false
