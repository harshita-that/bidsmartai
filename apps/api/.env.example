# ── API Server Environment Variables ──────────────────────────────
# Copy to .env for local development

NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://bidsmart:bidsmart_secret@localhost:5432/bidsmart_dev?schema=public"

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET="dev_access_secret_replace_in_production_min_64_chars_xxxxxxxxxxxxxxx"
JWT_REFRESH_SECRET="dev_refresh_secret_replace_in_production_min_64_chars_xxxxxxxxxxxxxx"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@bidsmart.ai"

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/oauth/google/callback"

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── ML Service ───────────────────────────────────────────────────
ML_SERVICE_URL="http://localhost:8000"
ML_SERVICE_TIMEOUT_MS=10000

# ── eBay API ─────────────────────────────────────────────────────
EBAY_APP_ID="your_ebay_app_id"
EBAY_CERT_ID="your_ebay_cert_id"
EBAY_DEV_ID="your_ebay_dev_id"
EBAY_ENVIRONMENT="sandbox"
