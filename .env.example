# ══════════════════════════════════════════════════════════════════
# BidSmart — Root Environment Variables Example
# Copy this to .env at the root and fill in real values.
# App-specific variables also exist in apps/web/.env and apps/api/.env
# ══════════════════════════════════════════════════════════════════

# ── Node Environment ──────────────────────────────────────────────
NODE_ENV=development

# ── API ───────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=localhost

# ── Database (PostgreSQL) ─────────────────────────────────────────
DATABASE_URL="postgresql://bidsmart:bidsmart_secret@localhost:5432/bidsmart_dev?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET="replace_with_64_char_random_secret_for_access_tokens"
JWT_REFRESH_SECRET="replace_with_64_char_random_secret_for_refresh_tokens"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@bidsmart.ai"

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/oauth/google/callback"

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID="price_xxxxxxxxxxxxxxxx"
STRIPE_PRO_ANNUAL_PRICE_ID="price_xxxxxxxxxxxxxxxx"
STRIPE_DEALER_MONTHLY_PRICE_ID="price_xxxxxxxxxxxxxxxx"
STRIPE_DEALER_ANNUAL_PRICE_ID="price_xxxxxxxxxxxxxxxx"

# ── eBay API ─────────────────────────────────────────────────────
EBAY_APP_ID="BidSmart-xxxxxxxx-PRD-xxxxxxxxxxxxxxxx-xxxxxxxx"
EBAY_CERT_ID="PRD-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EBAY_DEV_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
EBAY_ENVIRONMENT="sandbox"   # sandbox | production

# ── ML Service ───────────────────────────────────────────────────
ML_SERVICE_URL="http://localhost:8000"
ML_SERVICE_TIMEOUT_MS=10000

# ── Google Cloud Vision (Phase 5) ────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID="your_project_id"
GOOGLE_APPLICATION_CREDENTIALS="./gcp-key.json"

# ── AWS S3 / Object Storage (Phase 5+) ───────────────────────────
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="bidsmart-uploads"

# ── Frontend URLs ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
